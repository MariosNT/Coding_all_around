<Page
    x:Class="Lotto.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel x:Name="MainStack" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="wideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="narrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="320" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainStack.Orientation" Value="Vertical" />
                        <Setter Target="MainStack.HorizontalAlignment" Value="Center"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Image Height="200" Width="300" Source="/Assets/LottoBalls.png" />
        
        <StackPanel x:Name="GroupStack" Orientation="Vertical" VerticalAlignment="Center" >
            <StackPanel Orientation="Horizontal" Width="300" VerticalAlignment="Center">
                <TextBlock x:Name="Label1" Text="..."  Width="30" Margin="10" FontSize="28" TextAlignment="Center" />
                <TextBlock x:Name="Label2" Text="..."  Width="30" Margin="10" FontSize="28"  TextAlignment="Center" />
                <TextBlock x:Name="Label3" Text="..."  Width="30" Margin="10" FontSize="28"  TextAlignment="Center" />
                <TextBlock x:Name="Label4" Text="..."  Width="30" Margin="10" FontSize="28"  TextAlignment="Center" />
                <TextBlock x:Name="Label5" Text="..."  Width="30" Margin="10" FontSize="28"  TextAlignment="Center" />
                <TextBlock x:Name="Label6" Text="..."  Width="30" Margin="10" FontSize="28"  TextAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" >
                <Button x:Name="SelectButton" Width="130" Margin="10" Content="Select" IsEnabled="True" Click="SelectButton_Click" FontSize="20"/>
                <Button x:Name="ResetButton" Width="130" Margin="10" Content="Reset" IsEnabled="False" Click="ResetButton_Click" FontSize="20"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>

</Page>
